{
    "productName": "JARVIS",
    "version": "0.1.0",
    "identifier": "com.jarvis.ai",
    "build": {
        "beforeDevCommand": "cd ../../frontend && npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "",
        "frontendDist": "../../frontend/dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "JARVIS",
                "width": 1280,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "decorations": true,
                "transparent": false,
                "center": true,
                "visible": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ws://localhost:8420 http://localhost:8420 http://localhost:11434; img-src 'self' data: blob:"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "externalBin": [
            "binaries/jarvis-backend"
        ],
        "resources": [
            "../../backend/.env"
        ]
    }
}
