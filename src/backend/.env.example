# JARVIS Environment Configuration
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# ---- Gemini API ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- OpenRouter (optional) ----
# OPENROUTER_API_KEY=your_openrouter_key_here

# ---- Ollama ----
OLLAMA_URL=http://localhost:11434
JARVIS_DEFAULT_MODEL=jarvis

# ---- Voice ----
JARVIS_VOICE=0

# ---- Owner Profile ----
OWNER_NAME=YourName
OWNER_EMAIL=your_email@example.com
OWNER_PHONE=+1234567890
OWNER_INSTAGRAM=@your_instagram
OWNER_GITHUB=your_github_username

# ---- Email (for Gmail tools) ----
# JARVIS_EMAIL_USER=your_email@gmail.com
# JARVIS_EMAIL_PASSWORD=your_app_password

# ---- Notification (WhatsApp via CallMeBot) ----
# To enable: send "I allow callmebot to send me messages" to +34 644 59 71 67 on WhatsApp
# CALLMEBOT_API_KEY=your_api_key_here

# ---- Telegram Bot (two-way remote control) ----
# 1) Open Telegram -> search @BotFather -> /newbot -> get token
# 2) Set the token below
# 3) Send any message to your bot -> chat ID auto-saved
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=auto_detected
