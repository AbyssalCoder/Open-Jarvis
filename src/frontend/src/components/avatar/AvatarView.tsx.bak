/**
 * AvatarView — Animated Anime Girl Avatar Mode
 * Renders a local VRM anime model via Three.js + @pixiv/three-vrm.
 * Model: VRoid Studio female character (bundled locally — instant load).
 */

import { useRef, useEffect, useCallback, useState } from 'react';
import { Canvas, useFrame, useThree } from '@react-three/fiber';
import { VRMLoaderPlugin, VRM, VRMUtils, VRMExpressionPresetName } from '@pixiv/three-vrm';
import * as THREE from 'three';
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
import { useVoiceStore, useAIStore } from '@/core/store';

// ── Heart particle canvas ──────────────────────────────────────────────

function drawHeart(ctx: CanvasRenderingContext2D, x: number, y: number, size: number) {
    ctx.beginPath();
    const top = size * 0.3;
    ctx.moveTo(x, y + top);
    ctx.bezierCurveTo(x, y, x - size / 2, y, x - size / 2, y + top);
    ctx.bezierCurveTo(x - size / 2, y + (size + top) / 2, x, y + (size + top) / 1.3, x, y + size);
    ctx.bezierCurveTo(x, y + (size + top) / 1.3, x + size / 2, y + (size + top) / 2, x + size / 2, y + top);
    ctx.bezierCurveTo(x + size / 2, y, x, y, x, y + top);
    ctx.closePath();
}

interface Heart {
    x: number; y: number; size: number; speed: number; opacity: number; rot: number; drift: number;
}

function spawnHeart(w: number, h: number): Heart {
    return {
        x: Math.random() * w,
        y: h + 20 + Math.random() * 40,
        size: 6 + Math.random() * 14,
        speed: 0.3 + Math.random() * 0.7,
        opacity: 0.1 + Math.random() * 0.3,
        rot: Math.random() * Math.PI * 2,
        drift: (Math.random() - 0.5) * 0.4,
    };
}

function HeartOverlay({ speaking }: { speaking: boolean }) {
    const canvasRef = useRef<HTMLCanvasElement>(null);
    const heartsRef = useRef<Heart[]>([]);
    const animRef = useRef(0);
    const tRef = useRef(0);

    useEffect(() => {
        const canvas = canvasRef.current;
        if (!canvas) return;

        const render = () => {
            const ctx = canvas.getContext('2d');
            if (!ctx) return;
            const dpr = window.devicePixelRatio || 1;
            const w = canvas.clientWidth;
            const h = canvas.clientHeight;
            canvas.width = w * dpr;
            canvas.height = h * dpr;
            ctx.scale(dpr, dpr);
            tRef.current += 1 / 60;
            const t = tRef.current;

            ctx.clearRect(0, 0, w, h);

            // Spawn hearts
            const targetCount = speaking ? 18 : 8;
            while (heartsRef.current.length < targetCount) {
                heartsRef.current.push(spawnHeart(w, h));
            }

            // Update & draw hearts
            heartsRef.current.forEach((heart) => {
                heart.y -= heart.speed;
                heart.x += Math.sin(t * 0.8 + heart.rot) * 0.5 + heart.drift;
                heart.rot += 0.005;

                if (heart.y < -30) {
                    Object.assign(heart, spawnHeart(w, h));
                }

                ctx.save();
                ctx.translate(heart.x, heart.y);
                ctx.rotate(Math.sin(t + heart.rot) * 0.15);
                ctx.fillStyle = `rgba(255, 105, 180, ${heart.opacity})`;
                drawHeart(ctx, 0, 0, heart.size);
                ctx.fill();
                ctx.restore();
            });

            // Sparkle dots
            if (speaking) {
                for (let i = 0; i < 3; i++) {
                    const sx = w * 0.3 + Math.random() * w * 0.4;
                    const sy = h * 0.2 + Math.random() * h * 0.5;
                    ctx.fillStyle = `rgba(255, 182, 193, ${0.3 + Math.random() * 0.4})`;
                    ctx.beginPath();
                    ctx.arc(sx, sy, 1 + Math.random() * 2, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            animRef.current = requestAnimationFrame(render);
        };

        animRef.current = requestAnimationFrame(render);
        return () => cancelAnimationFrame(animRef.current);
    }, [speaking]);

    return (
        <canvas
            ref={canvasRef}
            style={{
                position: 'absolute',
                inset: 0,
                width: '100%',
                height: '100%',
                pointerEvents: 'none',
                zIndex: 2,
            }}
        />
    );
}

// ── VRM 3D Model ──────────────────────────────────────────────────────

function VRMModel({ speaking, thinking, onLoaded }: {
    speaking: boolean;
    thinking: boolean;
    onLoaded: () => void;
}) {
    const vrmRef = useRef<VRM | null>(null);
    const { scene } = useThree();
    const blinkTimer = useRef(0);
    const nextBlink = useRef(3 + Math.random() * 3);
    const loadedRef = useRef(false);

    useEffect(() => {
        if (loadedRef.current) return;
        loadedRef.current = true;

        const loader = new GLTFLoader();
        loader.register((parser) => new VRMLoaderPlugin(parser));

        loader.load(
            '/models/avatar.vrm',
            (gltf) => {
                const vrm = gltf.userData.vrm as VRM;
                if (!vrm) { onLoaded(); return; }

                VRMUtils.removeUnnecessaryJoints(vrm.scene);
                VRMUtils.removeUnnecessaryVertices(vrm.scene);

                vrm.scene.position.set(0, -1.35, 0);
                vrm.scene.rotation.y = Math.PI; // face camera

                scene.add(vrm.scene);
                vrmRef.current = vrm;
                onLoaded();
                console.log('[JARVIS Avatar] VRM model loaded');
            },
            undefined,
            (err) => {
                console.error('[JARVIS Avatar] VRM load error:', err);
                onLoaded();
            }
        );

        return () => {
            if (vrmRef.current) {
                scene.remove(vrmRef.current.scene);
                vrmRef.current = null;
            }
        };
    // eslint-disable-next-line react-hooks/exhaustive-deps
    }, []);

    useFrame((_, delta) => {
        const vrm = vrmRef.current;
        if (!vrm) return;

        const t = performance.now() / 1000;

        // Breathing
        vrm.scene.position.y = -1.35 + Math.sin(t * 1.5) * 0.008;
        // Idle sway
        vrm.scene.rotation.y = Math.PI + Math.sin(t * 0.4) * 0.02;

        // Blinking
        blinkTimer.current += delta;
        if (blinkTimer.current > nextBlink.current) {
            const p = (blinkTimer.current - nextBlink.current) * 8;
            if (p < 1) {
                vrm.expressionManager?.setValue(VRMExpressionPresetName.Blink, Math.sin(p * Math.PI));
            } else {
                vrm.expressionManager?.setValue(VRMExpressionPresetName.Blink, 0);
                blinkTimer.current = 0;
                nextBlink.current = 2 + Math.random() * 4;
            }
        }

        // Speaking — mouth + happy expression
        if (speaking) {
            vrm.expressionManager?.setValue(VRMExpressionPresetName.Aa,
                Math.abs(Math.sin(t * 8)) * 0.5);
            vrm.expressionManager?.setValue(VRMExpressionPresetName.Happy, 0.3);
        } else {
            vrm.expressionManager?.setValue(VRMExpressionPresetName.Aa, 0);
            vrm.expressionManager?.setValue(VRMExpressionPresetName.Happy, thinking ? 0 : 0.15);
        }

        vrm.update(delta);
    });

    return null;
}

// ── R3F Scene ──────────────────────────────────────────────────────────

function AvatarScene({ speaking, thinking, onLoaded }: {
    speaking: boolean; thinking: boolean; onLoaded: () => void;
}) {
    return (
        <Canvas
            camera={{ position: [0, 0, 2.0], fov: 25 }}
            style={{ position: 'absolute', inset: 0, zIndex: 1 }}
            gl={{
                antialias: true,
                toneMapping: THREE.ACESFilmicToneMapping,
                toneMappingExposure: 1.1,
            }}
        >
            <ambientLight intensity={0.5} color="#ffd1e8" />
            <directionalLight position={[2, 3, 2]} intensity={1.0} />
            <directionalLight position={[-2, 1, 1]} intensity={0.4} color="#ff69b4" />
            <pointLight position={[0, 2, -1]} intensity={0.3} color="#bf5af2" />
            <directionalLight position={[0, 1, -2]} intensity={0.5} color="#ff69b4" />
            <VRMModel speaking={speaking} thinking={thinking} onLoaded={onLoaded} />
        </Canvas>
    );
}

// ── Main Export ────────────────────────────────────────────────────────

export function AvatarView() {
    const [loaded, setLoaded] = useState(false);
    const ttsPlaying = useVoiceStore((s) => s.ttsPlaying);
    const isThinking = useAIStore((s) => s.isThinking);
    const handleLoaded = useCallback(() => setLoaded(true), []);

    useEffect(() => {
        const t = setTimeout(() => setLoaded(true), 20000);
        return () => clearTimeout(t);
    }, []);

    return (
        <div className="fixed inset-0" style={{ zIndex: 1 }}>
            {/* Dark pink gradient background */}
            <div
                style={{
                    position: 'absolute',
                    inset: 0,
                    background: 'radial-gradient(ellipse at 50% 40%, #1a0a15 0%, #0d0510 50%, #050208 100%)',
                    zIndex: 0,
                }}
            />

            {/* Ambient pink glow */}
            <div
                style={{
                    position: 'absolute',
                    inset: 0,
                    zIndex: 2,
                    pointerEvents: 'none',
                    background: ttsPlaying
                        ? 'radial-gradient(ellipse at 50% 45%, rgba(255,105,180,0.12) 0%, transparent 60%)'
                        : 'radial-gradient(ellipse at 50% 45%, rgba(255,105,180,0.05) 0%, transparent 60%)',
                    transition: 'background 0.5s ease',
                }}
            />

            {/* Heart particle overlay */}
            <HeartOverlay speaking={ttsPlaying} />

            {/* Loading state */}
            {!loaded && (
                <div
                    style={{
                        position: 'absolute',
                        inset: 0,
                        zIndex: 10,
                        display: 'flex',
                        flexDirection: 'column',
                        alignItems: 'center',
                        justifyContent: 'center',
                        background: '#0D0510',
                    }}
                >
                    <div
                        style={{
                            width: 50,
                            height: 50,
                            border: '2px solid rgba(255,105,180,0.15)',
                            borderTop: '2px solid #FF69B4',
                            borderRadius: '50%',
                            animation: 'spin 1s linear infinite',
                        }}
                    />
                    <span
                        style={{
                            marginTop: 16,
                            fontFamily: 'monospace',
                            fontSize: 11,
                            color: '#FF69B4',
                            letterSpacing: 3,
                        }}
                    >
                        LOADING AVATAR
                    </span>
                </div>
            )}

            {/* R3F Canvas — renders the VRM model */}
            <AvatarScene speaking={ttsPlaying} thinking={isThinking} onLoaded={handleLoaded} />

            {/* Bottom vignette */}
            <div
                style={{
                    position: 'absolute',
                    bottom: 0,
                    left: 0,
                    right: 0,
                    height: 120,
                    background: 'linear-gradient(transparent, rgba(5,2,8,0.8))',
                    zIndex: 3,
                    pointerEvents: 'none',
                }}
            />

            {/* Status indicator */}
            <div
                style={{
                    position: 'absolute',
                    bottom: 20,
                    left: '50%',
                    transform: 'translateX(-50%)',
                    zIndex: 4,
                    pointerEvents: 'none',
                    textAlign: 'center',
                }}
            >
                {ttsPlaying && (
                    <span
                        style={{
                            fontFamily: '"JetBrains Mono", monospace',
                            fontSize: 10,
                            color: 'rgba(255,105,180,0.7)',
                            letterSpacing: 2,
                            animation: 'pulse 1.5s ease infinite',
                        }}
                    >
                        ♪ SPEAKING...
                    </span>
                )}
                {!ttsPlaying && isThinking && (
                    <span
                        style={{
                            fontFamily: '"JetBrains Mono", monospace',
                            fontSize: 10,
                            color: 'rgba(191,90,242,0.7)',
                            letterSpacing: 2,
                            animation: 'pulse 2s ease infinite',
                        }}
                    >
                        THINKING...
                    </span>
                )}
            </div>

            {/* Ring glow when speaking */}
            {ttsPlaying && (
                <div
                    style={{
                        position: 'absolute',
                        top: '50%',
                        left: '50%',
                        transform: 'translate(-50%, -50%)',
                        width: 320,
                        height: 320,
                        borderRadius: '50%',
                        border: '1px solid rgba(255,105,180,0.15)',
                        boxShadow: '0 0 60px rgba(255,105,180,0.1), inset 0 0 60px rgba(255,105,180,0.05)',
                        animation: 'pulse 2s ease infinite',
                        zIndex: 3,
                        pointerEvents: 'none',
                    }}
                />
            )}

            <style>{`
                @keyframes spin { to { transform: rotate(360deg); } }
                @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
            `}</style>
        </div>
    );
}
