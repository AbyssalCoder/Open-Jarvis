{
    "name": "jarvis",
    "version": "0.1.0",
    "private": true,
    "description": "JARVIS — Local-first AI Operating System",
    "scripts": {
        "dev:frontend": "cd src/frontend && npm run dev",
        "dev:desktop": "cd src/desktop && cargo tauri dev",
        "build:frontend": "cd src/frontend && npm run build",
        "build:desktop": "cd src/desktop && cargo tauri build",
        "backend": "cd src/backend && python main.py",
        "setup": "node scripts/setup.js"
    },
    "workspaces": [
        "src/frontend"
    ],
    "license": "MIT",
    "devDependencies": {
        "@tauri-apps/cli": "^2.11.2"
    }
}
